{
  "type": "module",
  "name": "@heroku/heroku-cli-util",
  "version": "10.8.3",
  "description": "Set of helpful CLI utilities",
  "author": "Heroku",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/heroku/heroku-cli-util.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./color": {
      "types": "./dist/ux/colors.d.ts",
      "import": "./dist/ux/colors.js",
      "default": "./dist/ux/colors.js"
    },
    "./colors": {
      "types": "./dist/ux/colors.d.ts",
      "import": "./dist/ux/colors.js",
      "default": "./dist/ux/colors.js"
    },
    "./hux": {
      "types": "./dist/ux/index.d.ts",
      "import": "./dist/ux/index.js",
      "default": "./dist/ux/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    },
    "./utils/pg": {
      "types": "./dist/utils/pg/index.d.ts",
      "import": "./dist/utils/pg/index.js",
      "default": "./dist/utils/pg/index.js"
    },
    "./utils/addons": {
      "types": "./dist/utils/addons/index.d.ts",
      "import": "./dist/utils/addons/index.js",
      "default": "./dist/utils/addons/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@heroku-cli/schema": "^2.0.0",
    "@heroku-cli/test-utils": "^0.3.0",
    "@types/debug": "^4.1.12",
    "@types/node": "^22.15.3",
    "@types/tmp": "^0.2.6",
    "@types/tunnel-ssh": "4.1.1",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9",
    "eslint-config-oclif": "^6.0.144",
    "eslint-plugin-vitest": "^0.5.4",
    "mock-stdin": "^1.0.0",
    "nock": "^14.0.11",
    "tmp": "^0.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@heroku-cli/command": "^12.4.2",
    "@heroku/http-call": "^5.5.0",
    "@oclif/core": "^4.3.0",
    "@oclif/table": "0.5.9",
    "ansis": "^4.1.0",
    "debug": "^4.4.0",
    "inquirer": "^12.6.1",
    "open": "^11",
    "printf": "^0.6.1",
    "tsheredoc": "^1.0.1",
    "tunnel-ssh": "5.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "example": "sh examples/run.sh",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  }
}
