{
  "type": "module",
  "name": "@heroku/heroku-cli-util",
  "version": "10.7.0-beta.0",
  "description": "Set of helpful CLI utilities",
  "author": "Heroku",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/heroku/heroku-cli-util.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./color": {
      "types": "./dist/ux/colors.d.ts",
      "import": "./dist/ux/colors.js",
      "default": "./dist/ux/colors.js"
    },
    "./colors": {
      "types": "./dist/ux/colors.d.ts",
      "import": "./dist/ux/colors.js",
      "default": "./dist/ux/colors.js"
    },
    "./hux": {
      "types": "./dist/ux/index.d.ts",
      "import": "./dist/ux/index.js",
      "default": "./dist/ux/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    },
    "./utils/pg": {
      "types": "./dist/utils/pg/index.d.ts",
      "import": "./dist/utils/pg/index.js",
      "default": "./dist/utils/pg/index.js"
    },
    "./utils/addons": {
      "types": "./dist/utils/addons/index.d.ts",
      "import": "./dist/utils/addons/index.js",
      "default": "./dist/utils/addons/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@heroku-cli/schema": "^2.0.0",
    "@heroku-cli/test-utils": "^0.2.0",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/debug": "^4.1.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.3",
    "@types/sinon": "^20.0.0",
    "@types/sinon-chai": "^4.0.0",
    "@types/tmp": "^0.2.6",
    "@types/tunnel-ssh": "4.1.1",
    "c8": "^11.0.0",
    "chai": "^5.3.3",
    "chai-as-promised": "^8.0.2",
    "eslint": "^9",
    "eslint-config-oclif": "^6.0.144",
    "mocha": "^11",
    "mock-stdin": "^1.0.0",
    "nock": "^14.0.11",
    "open": "^11",
    "sinon": "^20.0.0",
    "sinon-chai": "^4.0.1",
    "tmp": "^0.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@heroku-cli/command": "^12.2.0",
    "@heroku/http-call": "^5.5.0",
    "@oclif/core": "^4.3.0",
    "@oclif/table": "0.5.2",
    "ansis": "^4.1.0",
    "debug": "^4.4.0",
    "inquirer": "^12.6.1",
    "printf": "^0.6.1",
    "tsheredoc": "^1.0.1",
    "tunnel-ssh": "5.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "example": "sh examples/run.sh",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "prepare": "npm run build",
    "test": "npm run build && c8 --all --check-coverage --reporter=lcov --reporter=text-summary mocha --forbid-only \"test/**/*.test.ts\""
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  }
}
